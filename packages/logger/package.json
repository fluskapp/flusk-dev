{
  "name": "@flusk/logger",
  "version": "0.1.2",
  "type": "module",
  "description": "Structured logging for Flusk platform — powered by Pino",
  "main": "./src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.0"
  }
}
