{
  "name": "@flusk/resources",
  "version": "0.1.0",
  "description": "Database repositories, cache clients, and I/O operations for Flusk",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./repositories/*": "./dist/repositories/*.js",
    "./cache/*": "./dist/cache/*.js",
    "./clients/*": "./dist/clients/*.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flusk/business-logic": "workspace:*",
    "@flusk/entities": "workspace:*",
    "@flusk/types": "workspace:*",
    "@sinclair/typebox": "^0.32.0",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3"
  }
}
