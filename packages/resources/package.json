{
  "name": "@flusk/resources",
  "version": "0.1.0",
  "description": "Database repositories, cache clients, and I/O operations for Flusk",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flusk/business-logic": "workspace:*",
    "@flusk/entities": "workspace:*",
    "@flusk/logger": "workspace:*",
    "@flusk/types": "workspace:*",
    "@sinclair/typebox": "^0.32.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3"
  }
}
