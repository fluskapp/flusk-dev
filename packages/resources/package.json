{
  "name": "@flusk/resources",
  "version": "0.1.0",
  "description": "Database repositories, cache clients, and I/O operations for Flusk",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db/pool": "./src/db/pool.ts",
    "./repositories/llm-call": "./src/repositories/llm-call/index.ts",
    "./repositories/pattern": "./src/repositories/pattern/index.ts",
    "./repositories/conversion": "./src/repositories/conversion/index.ts",
    "./cache/redis.client": "./src/cache/redis.client.ts",
    "./clients/*": "./src/clients/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flusk/business-logic": "workspace:*",
    "@flusk/entities": "workspace:*",
    "@flusk/types": "workspace:*",
    "@sinclair/typebox": "^0.32.0",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3"
  }
}
