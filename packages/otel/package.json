{
  "name": "@flusk/otel",
  "version": "0.1.0",
  "description": "Zero-touch OpenTelemetry auto-instrumentation for Flusk — node --require @flusk/otel",
  "type": "module",
  "main": "./dist/register.js",
  "types": "./dist/register.d.ts",
  "exports": {
    ".": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "require": "./dist/register.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flusk/business-logic": "workspace:*",
    "@flusk/logger": "workspace:*",
    "@flusk/resources": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@traceloop/instrumentation-bedrock": "^0.22.6",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0"
  },
  "peerDependencies": {
    "@platformatic/flame": "^1.6.0"
  },
  "peerDependenciesMeta": {
    "@platformatic/flame": {
      "optional": true
    }
  },
  "keywords": [
    "flusk",
    "opentelemetry",
    "otel",
    "llm",
    "observability",
    "auto-instrumentation"
  ]
}
