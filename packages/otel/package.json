{
  "name": "@flusk/otel",
  "version": "0.2.3",
  "description": "Zero-touch OpenTelemetry auto-instrumentation for Flusk — node --require @flusk/otel",
  "type": "module",
  "main": "./src/register.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flusk/business-logic": "workspace:*",
    "@flusk/logger": "workspace:*",
    "@flusk/resources": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/core": "^2.5.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@traceloop/instrumentation-bedrock": "^0.22.6",
    "@traceloop/instrumentation-openai": "^0.22.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.20.0",
    "@platformatic/flame": "^1.6.0"
  },
  "peerDependenciesMeta": {
    "@platformatic/flame": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    }
  },
  "keywords": [
    "flusk",
    "opentelemetry",
    "otel",
    "llm",
    "observability",
    "auto-instrumentation"
  ],
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@google/generative-ai": "^0.24.1",
    "cohere-ai": "^7.20.0"
  },
  "license": "MIT"
}
