{
  "name": "@flusk/forge",
  "version": "0.2.1",
  "type": "module",
  "main": "./src/index.ts",
  "description": "Code generation framework for Flusk — YAML to code",
  "scripts": {
    "build": "tsc",
    "test": "vitest run src/__tests__/ src/generators/command/__tests__/ src/generators/prompt/__tests__/ src/generators/action/__tests__/",
    "clean": "rm -rf dist",
    "dev": "tsc --watch"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@flusk/entities": "workspace:*",
    "@flusk/execution": "workspace:*",
    "@flusk/logger": "workspace:*",
    "@flusk/resources": "workspace:*",
    "@sinclair/typebox": "^0.34.48",
    "chalk": "^5.4.1",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "ora": "^8.0.0",
    "pg": "^8.13.1",
    "undici": "^7.21.0",
    "validator": "^13.12.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/validator": "^13.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
