"/**
 * @generated by @flusk/cli from test-widget.entity.ts
 * DO NOT EDIT - regenerate using: flusk g test-widget.entity.ts
 */

import type { FastifyInstance, FastifyRequest, FastifyReply } from 'fastify';
import { Type } from '@sinclair/typebox';
import { TestWidgetEntitySchema } from '@flusk/entities';
import { TestWidgetRepository } from '@flusk/resources';

/**
 * Request schema for creating TestWidget
 */
const CreateTestWidgetSchema = Type.Omit(TestWidgetEntitySchema, [
  'id',
  'createdAt',
  'updatedAt'
]);

/**
 * Response schema for TestWidget
 */
const TestWidgetResponseSchema = TestWidgetEntitySchema;

/**
 * Register TestWidget routes
 */
export async function testwidgetRoutes(
  fastify: FastifyInstance
): Promise<void> {
  /**
   * POST /test-widgets
   * Create new test-widget record
   */
  fastify.post(
    '/',
    {
      schema: {
        body: CreateTestWidgetSchema,
        response: {
          201: TestWidgetResponseSchema
        },
        tags: ['TestWidget'],
        description: 'Create a new test-widget record'
      }
    },
    async (request: FastifyRequest, reply: FastifyReply) => {
      const data = request.body as any;
      const created = await TestWidgetRepository.create(data);
      return reply.code(201).send(created);
    }
  );

  /**
   * GET /test-widgets/:id
   * Retrieve test-widget by UUID
   */
  fastify.get(
    '/:id',
    {
      schema: {
        params: Type.Object({
          id: Type.String({ format: 'uuid' })
        }),
        response: {
          200: TestWidgetResponseSchema,
          404: Type.Object({ error: Type.String() })
        },
        tags: ['TestWidget'],
        description: 'Get test-widget by ID'
      }
    },
    async (request: FastifyRequest<{ Params: { id: string } }>, reply: FastifyReply) => {
      const { id } = request.params;
      const entity = await TestWidgetRepository.findById(id);

      if (!entity) {
        return reply.code(404).send({ error: 'TestWidget not found' });
      }

      return reply.code(200).send(entity);
    }
  );
}
"
`;
