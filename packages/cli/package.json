{
  "name": "@flusk/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Code generator CLI for Flusk platform",
  "bin": {
    "flusk": "./bin/flusk.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "node --test --import=tsx src/**/*.test.ts",
    "test:watch": "node --test --watch --import=tsx src/**/*.test.ts",
    "test:e2e": "pnpm build && node --test tests/e2e/**/*.test.ts",
    "test:all": "pnpm test && pnpm test:e2e"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@flusk/entities": "workspace:*",
    "@flusk/execution": "workspace:*",
    "@flusk/logger": "workspace:*",
    "@flusk/resources": "workspace:*",
    "@platformatic/flame": "1.6.0",
    "@sinclair/typebox": "^0.34.48",
    "boxen": "^7.1.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "ink-spinner": "^5.0.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "pg": "^8.13.1",
    "undici": "^7.21.0",
    "validator": "^13.12.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.14",
    "@types/validator": "^13.12.2",
    "ink": "^5.2.1",
    "react": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}