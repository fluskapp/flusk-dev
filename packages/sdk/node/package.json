{
  "name": "@flusk/sdk",
  "version": "0.1.0",
  "description": "Flusk SDK for Node.js - AI agent instrumentation and LLM API optimization",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "flusk",
    "llm",
    "openai",
    "anthropic",
    "instrumentation",
    "optimization"
  ],
  "peerDependencies": {
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.20.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@types/node": "^22.0.0",
    "openai": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
