{
  "name": "@flusk/sdk",
  "version": "0.2.0",
  "description": "Flusk SDK for Node.js — programmatic API access (routing, optimizations, prompts, tracing)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["flusk", "llm", "optimization", "routing", "prompts"],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
