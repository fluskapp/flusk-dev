# OpenAI API Key (required)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Flusk API Key (for authentication)
# In production, use your organization's API key
# For local development, use the test key
FLUSK_API_KEY=test_org_key

# Flusk API Base URL
# For local development, use localhost
# For production, use your deployed Flusk instance
FLUSK_BASE_URL=http://localhost:3000
