# ============================================
# flusk - Environment Variables
# ============================================
# Copy this file to .env and update with your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================

# ============================================
# Application
# ============================================

# Node environment (development | production | test)
NODE_ENV=development

# ============================================
# Storage (SQLite)
# ============================================

# SQLite database path (default: ~/.flusk/data.db)
# FLUSK_SQLITE_PATH=~/.flusk/data.db

# ============================================
# Flusk Platform
# ============================================

# API authentication key
# Required — generate with: openssl rand -hex 32
FLUSK_API_KEY=

# HMAC secret for auth middleware
# Required — generate with: openssl rand -hex 32
FLUSK_HMAC_SECRET=

# Encryption key for sensitive data (AES-256-GCM)
# Required — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Agent label for CLI commands
# FLUSK_AGENT=my-agent

# ============================================
# LLM API Keys (for instrumented apps)
# ============================================

# OpenAI
# OPENAI_API_KEY=

# Anthropic
# ANTHROPIC_API_KEY=

# Google AI (Gemini)
# GOOGLE_AI_API_KEY=

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT_NAME=

# ============================================
# Observability
# ============================================

# OTLP exporter endpoint (for external backends)
# FLUSK_OTLP_ENDPOINT=http://localhost:4318

# CORS allowed origins (comma-separated, for server mode)
# FLUSK_CORS_ORIGIN=http://localhost:3000

# ============================================
# Logging
# ============================================

# Log level (fatal | error | warn | info | debug | trace)
FLUSK_LOG_LEVEL=info

# ============================================
# Privacy & Consent
# ============================================

# Whether telemetry data includes prompt content (default: true)
# FLUSK_CONSENT_GIVEN=true

# Purpose label for data collection
# FLUSK_CONSENT_PURPOSE=optimization

# ============================================
# Performance
# ============================================

# Scrypt cost parameter for key derivation (default: 16384)
# FLUSK_SCRYPT_COST=16384

# Data retention in days (for flusk purge)
# FLUSK_RETENTION_DAYS=30
