{
  "name": "flusk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source LLM cost optimization platform — zero-code tracking via OpenTelemetry",
  "keywords": [
    "llm",
    "opentelemetry",
    "cost-optimization",
    "openai",
    "anthropic",
    "observability"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AdirBenYossef/flusk.git"
  },
  "homepage": "https://github.com/AdirBenYossef/flusk",
  "license": "MIT",
  "author": "Adir Ben Yossef",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "docker:up": "docker compose up",
    "db:migrate": "tsx scripts/migrate.ts",
    "example": "cd examples && pnpm start",
    "test": "vitest run",
    "test:unit": "vitest run packages",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "cd tests && pnpm test",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "vercel-build": "pnpm build",
    "flusk": "node packages/cli/dist/bin/flusk.js",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vercel/node": "^3.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "glob": "^11.0.0",
    "minimatch": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@flusk/business-logic": "workspace:*",
    "@flusk/entities": "workspace:*",
    "@flusk/execution": "workspace:*",
    "@flusk/resources": "workspace:*",
    "@flusk/types": "workspace:*",
    "fastify": "^5.0.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pnpm": "^10.28.2"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.7",
      "path-to-regexp": ">=6.3.0"
    }
  }
}
